{
  "style": {
    "indent": "4 spaces",
    "maxLineLength": 120,
    "blankLinesBetweenMethods": 1,
    "curlyBraceStyle": "same-line"
  },
  "naming": {
    "classSuffixes": [
      "Service",
      "Controller",
      "Repository",
      "Entity",
      "DTO",
      "VO",
      "DAO",
      "Manager",
      "Handler",
      "Converter"
    ],
    "methodPrefixes": [
      "get",
      "set",
      "create",
      "update",
      "delete",
      "find",
      "list",
      "count",
      "save",
      "remove",
      "process",
      "handle",
      "validate",
      "convert",
      "build",
      "init",
      "destroy"
    ],
    "constantPattern": "^[A-Z][A-Z0-9_]*$",
    "variablePattern": "^[a-z][a-zA-Z0-9]*$"
  },
  "complexity": {
    "maxMethodLength": 50,
    "maxComplexity": 10,
    "maxNestingDepth": 3,
    "maxParameters": 5,
    "maxVariablesInMethod": 10
  },
  "maintainability": {
    "max дубликатовLines": 3,
    "magicNumberPatterns": [
      "\\d{5,}",
      "86400000",
      "3600000",
      "1000",
      "60000"
    ],
    "forbiddenPatterns": [
      "System.out",
      "e.printStackTrace",
      "new Thread()",
      "Thread.sleep"
    ]
  },
  "documentation": {
    "requireJavadocForPublicMethods": true,
    "requireJavadocForProtectedMethods": false,
    "maxNoCommentDays": 180,
    "todoPattern": "TODO:.*"
  },
  "security": {
    "forbiddenCalls": [
      "Runtime.exec",
      "ProcessBuilder",
      "Class.forName",
      "eval",
      "exec",
      "Statement",
      "PreparedStatement with concatenation"
    ],
    "requiredSanitizers": [
      "XSS",
      "SQL Injection",
      "Path Traversal"
    ]
  },
  "performance": {
    "maxLoopNesting": 2,
    "avoidNestedLoops": true,
    "collectionIterationStyle": "enhanced-for",
    "stringConcatenationInLoop": false
  },
  "sonar": {
    "enabled": true,
    "autoDetect": true,
    "scannerPath": "sonar-scanner",
    "projectKey": "${project.artifactId}",
    "host": "http://localhost:9000",
    "token": "",
    "qualityGate": true,
    "qualityProfiles": ["Sonar way"],
    "includeRules": [],
    "excludeRules": [],
    "reportFormat": "json",
    "mapping": {
      "BUG": "P0",
      "VULNERABILITY": "P0",
      "CODE_SMELL": "P1",
      "SECURITY_HOTSPOT": "P1",
      "TECHNICAL_DEBT": "P2"
    }
  },
  "diff": {
    "enabled": true,
    "autoFind": true,
    "reportPath": "./code-review-reports",
    "maxReportsToCompare": 10,
    "showTrend": true,
    "trendHistoryLimit": 5,
    "trendPrediction": true,
    "compareSonar": true,
    "compareQualityGate": true,
    "grouping": {
      "bySeverity": true,
      "byCategory": true,
      "byFile": false
    }
  }
}
